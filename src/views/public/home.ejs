<section class="hero reveal">
  <div class="hero__copy">
    <p class="hero__eyebrow"><%= hero.eyebrow %></p>
    <h1><%= hero.title %></h1>
    <p class="hero__lead"><%= hero.copy %></p>
    <div class="hero__actions">
      <a class="primary-button" href="<%= hero.primaryCta.href %>"><%= hero.primaryCta.label %></a>
      <a class="secondary-button" href="<%= hero.secondaryCta.href %>"><%= hero.secondaryCta.label %></a>
    </div>
    <ul class="hero__stats">
      <% highlights.forEach((item) => { %>
        <li>
          <strong><%= item.value %></strong>
          <span><%= item.label %></span>
        </li>
      <% }) %>
    </ul>
  </div>

  <div class="hero__panel">
    <div class="hero__shine"></div>
    <div class="hero__product">
      <span>Nueva temporada</span>
      <strong>Vestidos, blusas y piezas pensadas para elevar el look diario.</strong>
      <p>Una boutique digital con foco en detalle, suavidad visual y claridad de compra.</p>
    </div>
    <div class="hero__floating">
      <div>
        <strong>Entrega</strong>
        <span>Compra simplificada</span>
      </div>
      <div>
        <strong>Estilo</strong>
        <span>Elegancia femenina</span>
      </div>
    </div>
  </div>
</section>

<section class="section-shell reveal">
  <div class="section-heading">
    <p>Explora por categoria</p>
    <h2>Encuentra rapidamente lo que buscas</h2>
  </div>
  <div class="category-strip">
    <% categories.forEach((category) => { %>
      <a class="category-chip" href="/catalogo/categoria/<%= category.slug %>">
        <strong><%= category.name %></strong>
        <span><%= category._count.products %> piezas</span>
      </a>
    <% }) %>
  </div>
</section>

<section class="section-shell reveal">
  <div class="section-heading section-heading--split">
    <div>
      <p>Seleccion destacada</p>
      <h2>Piezas listas para convertirse en favoritas</h2>
    </div>
    <a class="text-link" href="/catalogo">Ver catalogo completo</a>
  </div>
  <div class="product-grid">
    <% featuredProducts.forEach((product) => { %>
      <%- include('./partials/product-card', { product }) %>
    <% }) %>
  </div>
</section>

<section class="section-shell reveal">
  <div class="section-heading section-heading--split">
    <div>
      <p>Recien llegadas</p>
      <h2>Lo ultimo de la boutique</h2>
    </div>
  </div>
  <div class="product-grid product-grid--compact">
    <% freshProducts.forEach((product) => { %>
      <%- include('./partials/product-card', { product }) %>
    <% }) %>
  </div>
</section>
