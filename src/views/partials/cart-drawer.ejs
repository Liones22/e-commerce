<aside class="cart-drawer" id="visual-cart" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Carrito visual">
    <div class="cart-drawer__head">
      <div>
        <p>Carrito visual</p>
        <strong data-cart-summary>0 articulos</strong>
      </div>
      <button type="button" class="icon-button" data-cart-close aria-label="Cerrar carrito">×</button>
    </div>
    <div class="cart-drawer__body" data-cart-items>
      <div class="cart-empty">Agrega productos para ver tu carrito visual.</div>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total">
        <span>Total visual</span>
        <strong data-cart-total>$0</strong>
      </div>
      <a class="checkout-link" href="/carrito">Ir al carrito</a>
    </div>
  </div>
</aside>
